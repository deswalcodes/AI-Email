# ---- LLM provider: "gemini" (free) or "openai" ----
LLM_PROVIDER=gemini

# ---- Google Gemini (free key: https://aistudio.google.com/apikey) ----
GEMINI_API_KEY=your-gemini-key-here
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=text-embedding-004

# ---- OpenAI (used only if LLM_PROVIDER=openai) ----
OPENAI_API_KEY=sk-your-key-here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# ---- Gmail OAuth (from Google Cloud Console) ----
# Download an OAuth 2.0 "Desktop app" / "Web application" client and paste values here,
# OR place the downloaded JSON at backend/credentials.json (GOOGLE_CLIENT_SECRETS_FILE).
GOOGLE_CLIENT_SECRETS_FILE=credentials.json
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/gmail/oauth/callback

# ---- App behaviour ----
# auto_send  -> AI replies are sent automatically
# approve    -> AI drafts a reply, a human approves before sending
REPLY_MODE=approve
# AI confidence below this (0-1) forces human escalation
CONFIDENCE_THRESHOLD=0.7
# How many messages in a thread from an angry customer triggers escalation
ANGRY_CONTACT_THRESHOLD=3
